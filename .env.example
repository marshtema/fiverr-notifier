# ====== Telegram ======
# Токен бота от @BotFather (пример: 123456789:ABCdefGhIJKlmNoPQRsTUvwxyz)
TELEGRAM_BOT_TOKEN=
# Твой chat_id (узнаем при первом запуске через /start)
TELEGRAM_CHAT_ID=

# ====== Gmail ======
# Адрес почты, на которую приходят письма от Fiverr
GMAIL_ADDRESS=
# App Password (16 символов), НЕ обычный пароль от почты
GMAIL_APP_PASSWORD=

# ====== AI (Google Gemini, бесплатно) ======
# Включить AI-обработку (true/false). Если false — шлём без выжимки.
AI_ENABLED=true
# API-ключ Gemini с https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Модель (по умолчанию бесплатная и быстрая)
GEMINI_MODEL=gemini-2.5-flash

# ====== Общее ======
# Как часто проверять почту (секунды) — только для режима цикла на ПК
CHECK_INTERVAL_SECONDS=30
# На каком языке писать выжимку AI (ru/en)
NOTIFY_LANGUAGE=ru
# Слать ли уведомления о неопознанных письмах Fiverr (true = больше уведомлений)
NOTIFY_UNKNOWN=false
# Помечать письма прочитанными после обработки (для GitHub Actions держи true)
MARK_SEEN=true
